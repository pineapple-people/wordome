{
  "amazon": {
    "product_meta": {
    "container": "body",
    "selectors": {
        "product_id": { "css": "input#ASIN", "attr": "value" },
        "product_name": { "css": "h1#title", "type": "text" }, 
        "price":{ "css": "#corePrice_feature_div .a-offscreen, .apexPriceToPay .a-offscreen, .a-price .a-offscreen", "type": "text" }, 
        "brand": { "css": "th:contains('Brand Name') + td", "type": "text" }, 
        "manufacturer": { "css": "th:contains('Manufacturer') + td", "type": "text" },
        "category_raw": { "css": "li:-soup-contains('Best Sellers Rank'), tr:-soup-contains('Best Sellers Rank') td", "type": "text" },
        "average_rate": { "css": "span.a-icon-alt", "type": "text" },
        "total_ratings": { "css": "#acrCustomerReviewText", "type": "text" }
    }
  },  

    "review_selectors":  {
      "container": "li[data-hook='review']",
      "selectors": {
        "product_id": { "css": "input#ASIN", "attr": "value" },
        "review_id": { "attr": "id" },
        "rating": { "css": "i[data-hook='review-star-rating'] span.a-icon-alt", "type": "text" },
        "title": { "css": "a[data-hook='review-title'] > span:last-child", "type": "text" },
        "content": { "css": "span[data-hook='review-body'] span", "type": "text" },
        "review_date": { "css": "span[data-hook='review-date']", "type": "text" },
        "is_verified": { "css": "span[data-hook='avp-badge']", "type": "text" }
      }
    }
  }
}