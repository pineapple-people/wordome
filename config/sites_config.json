{
  "amazon": {
    "product_meta": {
    "container": "#item_details",
    "selectors": {
        "product_id": { "css": "div#averageCustomerReviews", "attr": "data-asin" },
        "brand": { "css": "tr:nth-of-type(1) td", "type": "text" },
        "manufacturer": { "css": "tr:nth-of-type(5) td", "type": "text" },
        "category": { "css": "ul.a-unordered-list li:last-child span.a-list-item span", "type": "text" },
        "average_rate": { "css": "#averageCustomerReviews span.a-icon-alt", "type": "text" },
        "total_ratings": { "css": "#acrCustomerReviewText", "type": "text" }
      }
    },
    
    "review_selectors":  {
      "container": "li[data-hook='review']",
      "selectors": {
        "product_id": { "css": "div#averageCustomerReviews", "attr": "data-asin" },
        "review_id": { "attr": "id" },
        "rating": { "css": "i[data-hook='review-star-rating'] span.a-icon-alt", "type": "text" },
        "title": { "css": "a[data-hook='review-title'] > span:last-child", "type": "text" },
        "content": { "css": "span[data-hook='review-body'] span", "type": "text" },
        "review_date": { "css": "span[data-hook='review-date']", "type": "text" },
        "is_verified": { "css": "span[data-hook='avp-badge']", "type": "text" }
      }
    }
  }
}